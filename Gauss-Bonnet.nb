     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"gNumeric", "[", 
       RowBox[{"n", ",", "\[Lambda]", ",", "\[Chi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dg1", "=", 
      RowBox[{"ND", "[", 
       RowBox[{
        RowBox[{"gNumeric", "[", 
         RowBox[{"n", ",", "l", ",", "\[Chi]"}], "]"}], ",", "l", ",", 
        "\[Lambda]", ",", 
        RowBox[{"Terms", "\[Rule]", "derTerms"}], ",", 
        RowBox[{"Scale", "->", "scale"}], ",", 
        RowBox[{"Method", "->", "EulerSum"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dg2", "=", 
