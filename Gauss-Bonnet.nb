Cell[BoxData[
 RowBox[{
  RowBox[{"gCart", "[", 
   RowBox[{"level_", ",", "bx_", ",", "bz_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "m", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"m", "=", 
      RowBox[{"Quiet", "@", 
       RowBox[{"Check", "[", 
        RowBox[{
         RowBox[{"gC", "[", 
          RowBox[{"level", ",", 
           RowBox[{"N", "[", "bx", "]"}], ",", 
           RowBox[{"N", "[", "bz", "]"}]}], "]"}], ",", "$Failed"}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"m", "===", "$Failed"}], "||", 
        RowBox[{"!", 
         RowBox[{"MatrixQ", "[", 
          RowBox[{"m", ",", "NumericQ"}], "]"}]}]}], ",", "$Failed", ",", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "+", 
           RowBox[{"Transpose", "[", "m", "]"}]}], ")"}], "/", "2"}], "]"}]}],
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.987496855817428*^9, 3.9874968705323143`*^9}},
