       RowBox[{"R", ",", 
        RowBox[{
         RowBox[{"1", "/", "2"}], "+", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}]}], ",", "Rout"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Phi", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "12"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Inner Manifold Contribution: \>\"", ",", "int3LIn"}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Outer Manifold Contribution: \>\"", ",", "int3LOut"}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
