     RowBox[{"phi_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dim", "=", "2"}], ",", "enNonSort", ",", "eigNonSort", ",", 
       "en", ",", "eig", ",", "M1", ",", "M1T", ",", "M2", ",", "M2T", ",", 
       "endif", ",", "g11", ",", "g12", ",", "g22"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"enNonSort", ",", "eigNonSort"}], "}"}], "=", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"H2LPolar", "[", 
         RowBox[{"r", ",", "phi"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eigNonSort", "=", 
       RowBox[{"Map", "[", 
        RowBox[{"Normalize", ",", "eigNonSort"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"en", ",", "eig"}], "}"}], "=", 
       RowBox[{"Transpose", "@", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"enNonSort", ",", "eigNonSort"}], "}"}], "]"}], ",", 
          "First"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Matrix", " ", "elements", " ", "connecting", " ", "band", " ", "1", " ",
         "to", " ", "band", " ", "2"}], "*)"}], 
      RowBox[{"M1", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"eig", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], ".", 
        RowBox[{"DH2Lr", "[", 
         RowBox[{"r", ",", "phi"}], "]"}], ".", 
        RowBox[{"eig", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"M1T", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"eig", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "]"}], ".", 
        RowBox[{"DH2Lr", "[", 
         RowBox[{"r", ",", "phi"}], "]"}], ".", 
        RowBox[{"eig", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"M2", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"eig", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], ".", 
        RowBox[{"DH2Lphi", "[", 
         RowBox[{"r", ",", "phi"}], "]"}], ".", 
        RowBox[{"eig", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"M2T", "=", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"eig", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "]"}], ".", 
        RowBox[{"DH2Lphi", "[", 
         RowBox[{"r", ",", "phi"}], "]"}], ".", 
        RowBox[{"eig", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"endif", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"en", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "-", 
          RowBox[{"en", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "^", "2"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g11", "=", 
       RowBox[{"Re", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"M1", "*", "M1T"}], ")"}], "/", "endif"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g12", "=", 
       RowBox[{"Re", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"M1", "*", "M2T"}], ")"}], "/", "endif"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g22", "=", 
       RowBox[{"Re", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"M2", "*", "M2T"}], ")"}], "/", "endif"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"g11", ",", "g12"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"g12", ",", "g22"}], "}"}]}], "}"}]}]}], "]"}]}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Integrate", " ", "over", " ", "a", " ", "disk", " ", "of", " ", "radius",
      " ", "rTarget"}], "=", "0.03"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rTarget2L", "=", "0.03"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<Integrating 2-level system...\>\"", "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"int2L", "=", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"CurvatureIntegrand", "[", 
       RowBox[{"g2L", ",", "r", ",", "phi"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}], ",", "rTarget2L"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"phi", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "10"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Topological phase for 2-Level patch (should be roughly -Pi/2 \
or -1.57): \>\"", ",", "int2L"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9872403573333883`*^9, 3.987240357336116*^9}, 
