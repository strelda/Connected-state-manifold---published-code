Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gSWrapped", "[", 
     RowBox[{
      RowBox[{"R_", "?", "NumericQ"}], ",", 
      RowBox[{"Phi_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"gS", "[", 
     RowBox[{"0", ",", "1", ",", "2", ",", 
      RowBox[{"{", 
       RowBox[{"R", ",", "Phi"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"rTarget3L", "=", "0.03"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Rin", "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "rTarget3L"}], "+", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "+", 
        RowBox[{"rTarget3L", "^", "2"}]}], "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Rout", "=", 
    RowBox[{
     RowBox[{"1", "/", "2"}], "*", 
     RowBox[{"(", 
      RowBox[{"rTarget3L", "+", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "+", 
         RowBox[{"rTarget3L", "^", "2"}]}], "]"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Integration domain for R: [\>\"", ",", "Rin", 
    ",", "\"\<, \>\"", ",", "Rout", ",", "\"\<] with horizon at 1/2\>\""}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<Integrating 3-level Inner Manifold...\>\"", "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"int3LIn", "=", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"CurvatureIntegrand", "[", 
       RowBox[{"gSWrapped", ",", "R", ",", "Phi"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"R", ",", "Rin", ",", 
        RowBox[{
         RowBox[{"1", "/", "2"}], "-", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Phi", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "12"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<Integrating 3-level Outer Manifold...\>\"", "]"}], 
