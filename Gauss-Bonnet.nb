Cell[BoxData[
 RowBox[{
  RowBox[{"gSLevel", "[", 
   RowBox[{
    RowBox[{"hamInt_", "?", "IntegerQ"}], ",", 
    RowBox[{"n_", "?", "IntegerQ"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Lambda]_", "?", "NumericQ"}], ",", 
      RowBox[{"\[Chi]_", "?", "NumericQ"}]}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "DH1", ",", "DH2", ",", "H", ",", "dim", ",", "dh1c", ",", "dh2c", ",", 
      "en", ",", "eig", ",", "M1", ",", "M1T", ",", "M2", ",", "M2T", ",", 
      "endif", ",", "g11", ",", "g12", ",", "g22", ",", "levels"}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"labeled", " ", "as", " ", "n"}], "=", "1"}], ",", "2", ",", 
      RowBox[{"3", " ", "states"}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dim", "=", "3"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"choose", " ", "H", " ", "nad", " ", "derivatives"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"H", ",", "DH1", ",", "DH2"}], "}"}], "=", 
      RowBox[{"Which", "[", 
       RowBox[{
        RowBox[{"hamInt", "==", "0"}], ",", 
        RowBox[{"{", 
         RowBox[{"HS0", ",", "DH1S0", ",", "DH2S0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"hamInt", "==", "1"}], ",", 
        RowBox[{"{", 
         RowBox[{"HS1", ",", "DH1S1", ",", "DH2S1"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"hamInt", "==", "2"}], ",", 
        RowBox[{"{", 
         RowBox[{"HS2", ",", "DH1S2", ",", "DH2S2"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"levels", "=", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{"Range", "[", "3", "]"}], ",", "n"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"en", ",", "eig"}], "}"}], "=", 
      RowBox[{"EigensystemSorted", "[", 
       RowBox[{"H", ",", "\[Lambda]", ",", "\[Chi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dh1c", "=", 
      RowBox[{"DH1", "[", 
       RowBox[{"\[Lambda]", ",", "\[Chi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dh2c", "=", 
      RowBox[{"DH2", "[", 
       RowBox[{"\[Lambda]", ",", "\[Chi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"M1", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{
          "eig", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], 
          "]"}], ".", "dh1c", ".", 
         RowBox[{
         "eig", "\[LeftDoubleBracket]", "#", "\[RightDoubleBracket]"}]}], 
        "&"}], "/@", "levels"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"M1T", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{
          "eig", "\[LeftDoubleBracket]", "#", "\[RightDoubleBracket]"}], 
          "]"}], ".", "dh1c", ".", 
         RowBox[{
         "eig", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}]}], 
        "&"}], "/@", "levels"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"M2", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{
          "eig", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], 
          "]"}], ".", "dh2c", ".", 
         RowBox[{
         "eig", "\[LeftDoubleBracket]", "#", "\[RightDoubleBracket]"}]}], 
        "&"}], "/@", "levels"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"M2T", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{
          "eig", "\[LeftDoubleBracket]", "#", "\[RightDoubleBracket]"}], 
          "]"}], ".", "dh2c", ".", 
         RowBox[{
         "eig", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}]}], 
        "&"}], "/@", "levels"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"endif", "=", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{
           "en", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], "-", 
           
           RowBox[{
           "en", "\[LeftDoubleBracket]", "#", "\[RightDoubleBracket]"}]}], 
          ")"}], "2"], "&"}], "/@", "levels"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"g11", "=", 
      RowBox[{"Re", "@", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
            "M1", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
            RowBox[{
            "M1T", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], 
           ")"}], "/", 
          RowBox[{
          "endif", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], ",", 
