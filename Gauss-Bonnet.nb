Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
    "=="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
   "FAST", " ", "APPROXIMATE", " ", "2", "D", " ", "INTEGRATOR", " ", 
    RowBox[{"(", 
     RowBox[{"Midpoint", " ", "Rule"}], ")"}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
    "=="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FastGridIntegrate", "[", 
      RowBox[{"integrand_", ",", 
       RowBox[{"{", 
        RowBox[{"xVar_", ",", "xMin_", ",", "xMax_", ",", "nX_"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"yVar_", ",", "yMin_", ",", "yMax_", ",", "nY_"}], "}"}]}], 
      "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dx", ",", "dy", ",", 
         RowBox[{"sum", "=", "0."}], ",", "xVal", ",", "yVal"}], "}"}], ",", 
       RowBox[{
        RowBox[{"dx", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"xMax", "-", "xMin"}], ")"}], "/", "nX"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"dy", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"yMax", "-", "yMin"}], ")"}], "/", "nY"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Sum", " ", "over", " ", "cell", " ", "midpoints", " ", "to", " ", 
          "avoid", " ", "boundary", " ", "singularities"}], "*)"}], 
        RowBox[{"sum", "=", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"xVal", "=", 
             RowBox[{"xMin", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"i", "-", "0.5"}], ")"}], "*", "dx"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"yVal", "=", 
             RowBox[{"yMin", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"j", "-", "0.5"}], ")"}], "*", "dy"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"integrand", "[", 
             RowBox[{"xVal", ",", "yVal"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "nX"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", "nY"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sum", "*", "dx", "*", "dy"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
     "=="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
