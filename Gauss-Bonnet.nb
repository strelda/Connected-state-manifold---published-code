     RowBox[{"LEVEL", " ", "SYSTEM", " ", "APPLICATION", " ", 
      RowBox[{"(", 
       RowBox[{"Fast", " ", "Version"}], ")"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
     "=="}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"gSWrapped", "[", 
      RowBox[{
       RowBox[{"R_", "?", "NumericQ"}], ",", 
       RowBox[{"Phi_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"gS", "[", 
      RowBox[{"0", ",", "1", ",", "2", ",", 
       RowBox[{"{", 
        RowBox[{"R", ",", "Phi"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rTarget3L", "=", "0.03"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Rin", "=", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "rTarget3L"}], "+", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "+", 
          RowBox[{"rTarget3L", "^", "2"}]}], "]"}]}], ")"}]}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"Rout", "=", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "*", 
      RowBox[{"(", 
       RowBox[{"rTarget3L", "+", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "+", 
          RowBox[{"rTarget3L", "^", "2"}]}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Grid", " ", 
      RowBox[{"Resolution", ":", 
       RowBox[{
       "Increase", " ", "these", " ", "numbers", " ", "for", " ", "higher", " ",
         "accuracy"}]}]}], ",", 
     RowBox[{"decrease", " ", "for", " ", "faster", " ", 
      RowBox[{"runtime", ".", 
       RowBox[{"{", 
        RowBox[{"30", ",", "30"}], "}"}]}], " ", "means", " ", "900", " ", 
      "evaluations", " ", "total", " ", "per", " ", "patch"}], ",", 
     RowBox[{"which", " ", "takes", " ", "just", " ", 
      RowBox[{"seconds", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nR", "=", "40"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nPhi", "=", "40"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
