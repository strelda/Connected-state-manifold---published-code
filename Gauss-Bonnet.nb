    RowBox[{"(*", 
     RowBox[{"Guttierez", " ", "formula"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"derTerms", "=", "4"}], ";", "\[IndentingNewLine]", 
     RowBox[{"derTermsIn", "=", "4"}], ";", "\[IndentingNewLine]", 
