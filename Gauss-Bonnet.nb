     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "^", "2"}]}], "}"}]}], 
      "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Testing integration on a Unit Sphere...\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "integrate", " ", "slightly", " ", "away", " ", "from", " ", 
     "the", " ", "poles", " ", 
     RowBox[{"(", 
      RowBox[{"0", " ", "and", " ", "Pi"}], ")"}], " ", "to", " ", "avoid", " ",
      "coordinate", " ", "singularities"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sphereInt", "=", 
     RowBox[{"FastGridIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CurvatureIntegrand", "[", 
         RowBox[{"gSphere", ",", "#1", ",", "#2"}], "]"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "4"}]}], ",", 
         RowBox[{"Pi", "-", 
          RowBox[{"10", "^", 
           RowBox[{"-", "4"}]}]}], ",", "100"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", "0", ",", 
         RowBox[{"2", " ", "Pi"}], ",", "100"}], "}"}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Sphere Integrated Curvature (Expected 4\[Pi] \[TildeTilde] \
