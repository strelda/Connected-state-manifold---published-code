Cell["So the energy gap is 2e.", "Text",
 CellChangeTimes->{{3.985419820892166*^9, 
  3.98541983317424*^9}},ExpressionUUID->"4905656b-a847-446f-9076-\
0fed08f87e98"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"d", "=", "2.87"}], ";"}], "      ", 
  RowBox[{"(*", " ", 
   RowBox[{"GHz", "-", "zero", "-", 
    RowBox[{"field", " ", "splitting"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"e", "=", "0.5"}], ";"}], "            ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"e", "~", "100"}], " ", "kHz", " ", "for", " ", "high", " ", 
     "purity", " ", "chemical", " ", "vapour", " ", "deposition", " ", 
     "grown", " ", "diamond", " ", "samples"}], ",", " ", 
    RowBox[{
    "but", " ", "we", " ", "need", " ", "0", " ", "to", " ", "get", " ", 
     "exact", " ", "crossing"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Mu]B", "=", "14"}], ";"}], "    ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"GHz", "/", "T"}], "-", 
    RowBox[{"effective", " ", "gyromagnetic", " ", "parameter"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "=", "2"}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Land\[EAcute]", " ", "g"}], "-", "factor"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Chop", "@", 
   RowBox[{"H", "[", 
    RowBox[{"Bx", ",", "Bz"}], "]"}]}], "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"endif1", "[", 
   RowBox[{"y_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "sp", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"sp", "=", 
      RowBox[{"Sort", "[", 
       RowBox[{"Eigenvalues", "[", 
        RowBox[{"N", "@", 
         RowBox[{"H", "[", 
          RowBox[{"0", ",", "y"}], "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sp", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"sp", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
