Cell[BoxData[{
 RowBox[{
  RowBox[{"R1", "[", 
   RowBox[{
    RowBox[{"n_", "?", "IntegerQ"}], ",", 
    RowBox[{"\[Lambda]_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Chi]_", "?", "NumericQ"}], ",", 
    RowBox[{"derTerms_", "?", "NumericQ"}], ",", 
    RowBox[{"scale_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"g", ",", "l", ",", "c", ",", "dg1", ",", "dg2", ",", "R12"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{"gNumeric", "[", 
       RowBox[{"n", ",", "\[Lambda]", ",", "\[Chi]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dg1", "=", 
      RowBox[{"ND", "[", 
       RowBox[{
        RowBox[{"gNumeric", "[", 
         RowBox[{"n", ",", "l", ",", "\[Chi]"}], "]"}], ",", "l", ",", 
        "\[Lambda]", ",", 
        RowBox[{"Terms", "\[Rule]", "derTerms"}], ",", 
        RowBox[{"Scale", "->", "scale"}], ",", 
        RowBox[{"Method", "->", "EulerSum"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dg2", "=", 
      RowBox[{"ND", "[", 
       RowBox[{
        RowBox[{"gNumeric", "[", 
         RowBox[{"n", ",", "\[Lambda]", ",", "c"}], "]"}], ",", "c", ",", 
        "\[Chi]", ",", 
        RowBox[{"Terms", "\[Rule]", "derTerms"}], ",", 
        RowBox[{"Scale", "->", "scale"}], ",", 
        RowBox[{"Method", "->", "EulerSum"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      FractionBox["1", 
       SqrtBox[
        RowBox[{"Abs", "@", 
         RowBox[{"Det", "[", "g", "]"}]}]]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"g", "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}], 
          RowBox[{"g", "\[LeftDoubleBracket]", 
           RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]], 
