    "=="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"VALIDATION", " ", 
    RowBox[{"TEST", ":", 
     RowBox[{"UNIT", " ", "SPHERE"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
    "=="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Metric", " ", "for", " ", "a", " ", "unit", " ", 
     RowBox[{"sphere", ":", 
      RowBox[{"ds", "^", "2"}]}]}], "=", 
    RowBox[{
     RowBox[{"d\[Theta]", "^", "2"}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "^", "2"}], " ", 
      RowBox[{"d\[Phi]", "^", "2"}]}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"gSphere", "[", 
      RowBox[{
       RowBox[{"\[Theta]_", "?", "NumericQ"}], ",", 
