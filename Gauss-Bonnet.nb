Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"d1u4", "[", 
    RowBox[{"f_", ",", "u_", ",", "v_", ",", "h_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"u", "+", 
          RowBox[{"2", " ", "h"}]}], ",", "v"}], "]"}]}], "+", 
      RowBox[{"8", " ", 
