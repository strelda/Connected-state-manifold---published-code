   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"H2LPolar", "[", 
     RowBox[{"r_", ",", "phi_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r", "*", 
        RowBox[{"Cos", "[", "phi", "]"}]}], ")"}], "*", "sx"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r", "*", 
        RowBox[{"Sin", "[", "phi", "]"}]}], ")"}], "*", "sz"}]}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Analytical", " ", "derivatives", " ", "of", " ", "Hamiltonian"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DH2Lr", "[", 
