Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Quiet", "@", 
  RowBox[{
   RowBox[{"ResourceFunction", "[", "\"\<PlotGrid\>\"", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"w2", ",", "val", ",", 
        RowBox[{"\[Theta]", "=", "2"}], ",", 
        RowBox[{"\[CurlyPhi]", "=", "0"}], ",", 
        RowBox[{"levels", "=", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], ",", "xs", ",", "zs", ",", 
        RowBox[{"samples", "=", "precision"}], ",", "tableVals", ",", 
        "plots"}], "}"}], ",", 
      RowBox[{
       RowBox[{"w2", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
           RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
           RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"val", "[", 
          RowBox[{"level_", "?", "IntegerQ"}], "]"}], "[", 
         RowBox[{
          RowBox[{"x_", "?", "NumericQ"}], ",", 
          RowBox[{"z_", "?", "NumericQ"}]}], "]"}], ":=", 
        RowBox[{"N", "@", 
         RowBox[{"Norm", "@", 
          RowBox[{"v3Raw", "[", 
           RowBox[{"x", ",", "z", ",", "level", ",", "w2"}], "]"}]}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xs", ",", "zs"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"-", "0.25"}], ",", "0.25", ",", "samples"}], "]"}], ",", 
          
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"-", "0.25"}], ",", "0.25", ",", "samples"}], "]"}]}], 
         "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tableVals", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"ParallelTable", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"val", "[", "l", "]"}], "[", 
            RowBox[{"x", ",", "z"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"l", ",", "levels"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"z", ",", "zs"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "xs"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"plots", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"l", ",", "k"}], "}"}], ",", 
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", "ldp", "}"}], ",", 
              RowBox[{
               RowBox[{"ldp", "=", 
                RowBox[{"ListDensityPlot", "[", 
                 RowBox[{
                  RowBox[{"tableVals", "[", 
                   RowBox[{"[", "l", "]"}], "]"}], ",", 
                  RowBox[{"DataRange", "->", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "0.25"}], ",", "0.25"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "0.25"}], ",", "0.25"}], "}"}]}], "}"}]}], ",", 
                  RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
                  RowBox[{"ColorFunction", "->", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"colorizer", "[", "#", "]"}], "&"}], ")"}]}], ",", 
                  RowBox[{"FrameLabel", "->", 
                   RowBox[{"{", 
                    
                    RowBox[{"\"\<\!\(\*SubscriptBox[\(B\), \(x\)]\)\>\"", 
                    ",", "\"\<\!\(\*SubscriptBox[\(B\), \(z\)]\)\>\""}], 
                    "}"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"Show", "[", 
                RowBox[{"ldp", ",", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"bgDP0Cart", ",", "bgDP1Cart", ",", "bgDP2Cart"}], 
                   "}"}], "[", 
                  RowBox[{"[", "l", "]"}], "]"}]}], "]"}]}]}], "]"}]}], "]"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"levels", ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1", ",", "2"}], "}"}]}], "}"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", "plots"}]}], "]"}], "}"}], "]"}]}]], "Input",
