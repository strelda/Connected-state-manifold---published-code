Cell[CellGroupData[{

Cell["Circular paths in extended coordinates", "Subsection",
 CellChangeTimes->{{3.965896112709015*^9, 3.96589611686572*^9}, {
  3.966327330076294*^9, 
  3.966327338118032*^9}},ExpressionUUID->"89a84a19-703f-474c-b2e5-\
6ae017a25c2c"],

Cell["In shifted radial coordinates the DP is circle with R=1/2", "Text",
 CellChangeTimes->{{3.965895878174667*^9, 
  3.9658958798137617`*^9}},ExpressionUUID->"ce840aeb-5850-4fa7-af0d-\
c6fe3501e3af"],

Cell[BoxData[
 RowBox[{
  RowBox[{"circle", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"EdgeForm", "[", 
       RowBox[{"{", 
        RowBox[{"MyRed", ",", "Thick", ",", "Dashed"}], "}"}], "]"}], ",", 
      RowBox[{"FaceForm", "[", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.08", "]"}], ",", "Black"}], "]"}], ",", 
      RowBox[{"Disk", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.966330542948868*^9, 3.966330621936431*^9}, {
   3.966336133474769*^9, 3.966336136328269*^9}, 3.981014051271562*^9, {
   3.981014322707617*^9, 3.981014350265181*^9}, {3.981014424595396*^9, 
   3.981014470958968*^9}},
 CellLabel->
  "In[112]:=",ExpressionUUID->"8b404240-3fd4-47e5-b430-aba11376bd80"],

Cell["\<\
We transform from Cartesian circle to radial, to shifted radial, to shifted \
Cartesian (just because these functions were easy to write) and get:\
\>", "Text",
 CellChangeTimes->{{3.965895895620818*^9, 
  3.9658959441849527`*^9}},ExpressionUUID->"ff1f6266-98e6-4b77-838a-\
92600865fb8e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"X1", "[", "t_", "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Sin", "[", "t", "]"}], ",", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], "+", "1"}]}], "}"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.965895893716783*^9, {3.965896784073683*^9, 3.965896816402206*^9}, {
   3.965897203674713*^9, 3.965897214970071*^9}, 3.965897262962433*^9, {
   3.966328585642023*^9, 3.966328590051321*^9}, 3.9663297174641542`*^9},
 CellLabel->
  "In[113]:=",ExpressionUUID->"62c19693-4aaf-4e43-ac33-ce7e88b8ea4b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"X2", "[", "t_", "]"}], ":=", 
  RowBox[{"Which", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"0", "<=", "t", "<", "\[Pi]"}], ",", 
    RowBox[{"-", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sin", "[", "t", "]"}], ",", 
       RowBox[{
        RowBox[{"Cos", "[", "t", "]"}], "+", "1"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\[Pi]", "<=", "t", "<", 
     RowBox[{"3", " ", "\[Pi]"}]}], ",", 
    RowBox[{"-", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"-", "t"}], "-", "\[Pi]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "-", "\[Pi]"}], "]"}], "-", "1"}]}], "}"}]}], ",",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"3", " ", "\[Pi]"}], "<=", "t", "<", 
     RowBox[{"4", " ", "\[Pi]"}]}], ",", 
    RowBox[{"-", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sin", "[", "t", "]"}], ",", 
       RowBox[{
        RowBox[{"Cos", "[", "t", "]"}], "+", "1"}]}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"X1", "[", "t_", "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Sin", "[", "t", "]"}], ",", 
      RowBox[{
       RowBox[{"Cos", "[", "t", "]"}], "+", "1"}]}], "}"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.965896806389297*^9, 3.9658969709573183`*^9}, {
   3.9658970049727993`*^9, 3.9658970566595182`*^9}, {3.965897155861149*^9, 
   3.965897212788003*^9}, 3.965897261905354*^9, {3.966328593063369*^9, 
   3.966328605561781*^9}, {3.966329715216609*^9, 3.966329716583067*^9}, 
   3.985246691818486*^9, 3.9853377908461723`*^9},
 CellLabel->
  "In[114]:=",ExpressionUUID->"1d7d1b59-d24e-44e4-b63f-de43b4e50d26"],

