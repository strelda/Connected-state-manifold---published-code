            RowBox[{"{", 
             RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "xs"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"y", ",", "ys"}], "}"}]}], "]"}]}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"sheet", "[", 
      RowBox[{"level_", ",", "style_"}], "]"}], ":=", 
     RowBox[{"ParametricPlot3D", "[", 
