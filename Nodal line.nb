Cell[CellGroupData[{

Cell["Real symmetry: section y=0", "Section",
 CellChangeTimes->{{3.965805537537223*^9, 
  3.9658055529040403`*^9}},ExpressionUUID->"cc71039a-f31b-4b6e-8b02-\
ec5738f869f1"],

Cell["\<\
For the real system, the Berry phase around DP has to be multiple of \[Pi], \
thus in the real gauge there has to be jump in the wavefunction . The point \
of this jump has to be consistent with the location of nodal line.\
\>", "Text",
 CellChangeTimes->{{3.965806122288904*^9, 
  3.965806178235116*^9}},ExpressionUUID->"bb833082-df7f-43d4-90ba-\
c26d8d1303fd"],

