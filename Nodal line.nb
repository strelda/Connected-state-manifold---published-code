Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Piecewise", " ", "rescaling", " ", "power", " ", "only", " ", "on", " ", 
     "black"}], "\[RightArrow]", 
    RowBox[{"white", " ", "segment"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"powerRescale", "[", "t_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"t", "<=", 
        RowBox[{"Pi", "/", "4"}]}], ",", "t", ",", 
       RowBox[{"(*", 
        RowBox[{"green", "\[RightArrow]", 
         RowBox[{"black", ":", "unchanged"}]}], "*)"}], 
       RowBox[{
        FractionBox["\[Pi]", "4"], "+", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"t", "-", 
             FractionBox["\[Pi]", "4"]}], 
            FractionBox["\[Pi]", "4"]], ")"}], "3"], " ", 
         FractionBox["\[Pi]", "4"]}]}]}], "              ", 
      RowBox[{"(*", 
       RowBox[{"black", "\[RightArrow]", 
        RowBox[{"white", ":", 
         RowBox[{
          RowBox[{"1", "/", "3"}], " ", "power"}]}]}], "*)"}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Full", " ", "pipeline", " ", "v"}], "\[RightArrow]", 
     RowBox[{"Blend", " ", "parameter"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"compositeScale", "[", "v_", "]"}], ":=", 
     RowBox[{"powerRescale", "[", 
      RowBox[{"ArcTan", "[", "v", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"colorizer", "[", "v_", "]"}], ":=", 
     RowBox[{"Blend", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "Green"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Pi", "/", "4"}], ",", "Black"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Pi", "/", "2"}], ",", "White"}], "}"}]}], "}"}], ",", 
       RowBox[{"compositeScale", "[", "v", "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Colorbar", " ", "must", " ", "use", " ", "the", " ", "same", " ", 
     "piecewise", " ", "rescaling", " ", "so", " ", "it", " ", "matches", " ",
      "the", " ", "plot"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"baseGradient", "=", 
     RowBox[{
      RowBox[{"Blend", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "Green"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Pi", "/", "4"}], ",", "Black"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], ",", "White"}], "}"}]}], "}"}], ",", 
        RowBox[{"powerRescale", "[", "#", "]"}]}], "]"}], "&"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "exact", " ", "ArcTan", " ", "angles", " ", 
     "for", " ", "the", " ", "colorbar", " ", "ticks", " ", "with", " ", 
     "MaTeX", " ", "formatting"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"customTicks", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "\"\<0\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Pi", "/", "4"}], ",", "\"\<\[Pi]/4\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Pi", "/", "2"}], "-", "0.001"}], ",", "\"\<\[Pi]/2\>\""}], 
        "}"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"leg", "=", 
     RowBox[{"BarLegend", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"baseGradient", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"Pi", "/", "2"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"LegendMarkerSize", "->", 
        RowBox[{"{", 
         RowBox[{"12", ",", "100"}], "}"}]}], ",", 
       RowBox[{"Ticks", "->", "customTicks"}]}], "]"}]}], ";"}]}]}]], "Input",\

