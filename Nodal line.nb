        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xx", ",", "yy", ",", "EE"}], "}"}], ",", 
          RowBox[{"colorizer", "[", 
           RowBox[{
            RowBox[{"val", "[", "level", "]"}], "[", 
            RowBox[{"xx", ",", "yy"}], "]"}], "]"}]}], "]"}]}], ",", 
       RowBox[{"PlotPoints", "->", "precision"}], ",", 
       RowBox[{"MaxRecursion", "->", "2"}], ",", 
       RowBox[{"PerformanceGoal", "->", "\"\<Quality\>\""}], ",", 
       RowBox[{"ViewPoint", "->", 
        RowBox[{"{", 
         RowBox[{"6.5", ",", "3", ",", "3."}], "}"}]}]}], "]"}]}], ";"}], 
