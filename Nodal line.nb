Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"plot", " ", "a", " ", "itself"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xs", "=", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"xmin", ",", "xmax", ",", "precision"}], "]"}]}], ",", 
        RowBox[{"ys", "=", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"ymin", ",", "ymax", ",", "precision"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"vals", "=", 
       RowBox[{"Flatten", "@", 
        RowBox[{"ParallelTable", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"val", "[", "lev", "]"}], "[", 
           RowBox[{"x", ",", "y"}], "]"}], ",", 
          RowBox[{"{", 
