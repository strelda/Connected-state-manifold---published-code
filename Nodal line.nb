        RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "ymin", ",", "ymax"}], "}"}], ",", 
       RowBox[{"Boxed", "->", "False"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"PlotStyle", "->", "style"}], ",", 
       RowBox[{"MeshFunctions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#3", "+", "1"}], "&"}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"6", " ", 
              RowBox[{"ArcTan", "[", 
               RowBox[{"#2", ",", "#1"}], "]"}]}], "]"}], "&"}], ")"}]}], 
         "}"}]}], ",", 
